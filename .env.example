FHIR_URL=https://hapi.fhir.org/baseR4
FHIR_TOKEN=your-fhir-token-here
FHIR_TIMEOUT=30

EHR_API_URL=https://ehr-system.local/api
EHR_API_KEY=your-ehr-api-key-here

RXNORM_API_URL=https://rxnav.nlm.nih.gov/REST
RXNORM_TIMEOUT=15

OPINION_PLATFORM_URL=https://promptopinion.local/api
OPINION_PLATFORM_KEY=your-opinion-key-here

LLM_API_KEY=your-llm-api-key-here
LLM_MODEL_NAME=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=your-anthropic-api-key-here
MODEL_NAME=claude-3-5-sonnet-20241022

DATABASE_URL=sqlite:///./healthcare_agent.db
DATABASE_ECHO=false

LOG_LEVEL=INFO
LOG_FILE=logs/healthcare_agent.log

ENABLE_AUTO_COMPLETE=true
AUTO_COMPLETE_THRESHOLD=0.8
ENABLE_HUMAN_REVIEW=true
ENABLE_AUDIT_LOGGING=true
MAX_WORKFLOW_STEPS=10
WORKFLOW_TIMEOUT=300
CHECKPOINT_INTERVAL=5

DEMO_PATIENT_ID=pat-12345
DEMO_PATIENT_IDS=90250303,90252386,90254981,90255893,90256829
DEMO_ENCOUNTER_ID=enc-67890
DEMO_ORG_ID=org-99999
DEMO_USER_ID=dr-smith
DEMO_CHIEF_COMPLAINT=Fever and cough for 3 days
DEMO_SYMPTOMS=fever,cough,sore throat
DEMO_SYMPTOM_DURATION=3 days
DEMO_TEMPERATURE=38.5
DEMO_HEART_RATE=95
DEMO_BLOOD_PRESSURE=120/80
DEMO_O2_SATURATION=97.0

SECRET_KEY=your-secret-key-for-encryption
ENVIRONMENT=development
DEBUG=true
